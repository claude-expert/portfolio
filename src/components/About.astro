---
---

<section id="about" class="py-24 px-6 relative overflow-hidden">
  <!-- Floating tech words canvas -->
  <canvas id="about-canvas" class="absolute inset-0 w-full h-full pointer-events-none" style="opacity:0.85;"></canvas>

  <div class="max-w-6xl mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Bio -->
      <div class="reveal">
        <div class="section-label">About</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight">
          I build web products<br/>
          <span class="gradient-text">that perform.</span>
        </h2>
        <div class="space-y-5 text-zinc-400 leading-relaxed text-lg">
          <p>
            I'm a senior full-stack, backend, and cloud engineer based in Mississauga, Ontario
            with 7+ years of experience building production-grade web applications, backend
            APIs, and cloud-native services across fintech, healthcare, and enterprise SaaS.
          </p>
          <p>
            My work spans turning complex product requirements into reliable, maintainable
            software across the UI, API, database, deployment, and production-support layers —
            supporting systems that process $50M+ in monthly transaction volume.
          </p>
          <p>
            I care about <span class="text-white font-medium">reliable software</span> that
            survives real production usage: explicit, documented APIs, automated tests, and
            observability that make systems easy to support long after they ship.
          </p>
        </div>

        <div class="flex flex-wrap gap-3 mt-8">
          <span class="tech-badge">React</span>
          <span class="tech-badge">Next.js</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">Node.js</span>
          <span class="tech-badge">Python / FastAPI</span>
          <span class="tech-badge">PostgreSQL</span>
          <span class="tech-badge">AWS</span>
        </div>
      </div>

      <!-- Right: Fact cards -->
      <div class="reveal reveal-delay-2">
        <div class="grid grid-cols-2 gap-4">
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">7+</div>
            <div class="text-zinc-300 font-medium">Years in software engineering</div>
            <div class="text-zinc-600 text-sm mt-1">2019 → Present</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">8</div>
            <div class="text-zinc-300 font-medium">Distributed services</div>
            <div class="text-zinc-600 text-sm mt-1">OAuth 2.0/OIDC & RBAC</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">87%</div>
            <div class="text-zinc-300 font-medium">Test coverage</div>
            <div class="text-zinc-600 text-sm mt-1">Raised from 42% via TDD</div>
          </div>
          <div class="card p-6">
            <div class="text-4xl font-black gradient-text mb-2">40%</div>
            <div class="text-zinc-300 font-medium">DB performance gains</div>
            <div class="text-zinc-600 text-sm mt-1">Indexing & query tuning</div>
          </div>
        </div>

        <!-- Education -->
        <div class="card p-6 mt-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5">
                <path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div>
              <div class="text-white font-semibold">University of Toronto Mississauga</div>
              <div class="text-zinc-400 text-sm mt-0.5">B.Sc. Computer Science</div>
              <div class="text-zinc-600 text-xs mt-1">Dean's List · Graduated 2019</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById('about-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');
  const ctx = canvas.getContext('2d')!;

  const resize = () => {
    canvas.width  = canvas.clientWidth  * devicePixelRatio;
    canvas.height = canvas.clientHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  };
  resize();
  window.addEventListener('resize', resize);

  const WORDS = [
    'React', 'Next.js', 'TypeScript', 'Node.js', 'Python', 'FastAPI',
    'PostgreSQL', 'MongoDB', 'Redis', 'AWS', 'Docker', 'Kubernetes',
    'GraphQL', 'REST', 'OAuth', 'RBAC', 'Git', 'CI/CD',
    'Lambda', 'ECS', 'SQS', 'CloudWatch', 'Jest', 'Pytest',
  ];

  const W = () => canvas.clientWidth;
  const H = () => canvas.clientHeight;

  const particles = WORDS.map((word, i) => ({
    word,
    x: Math.random() * W(),
    y: H() + Math.random() * H(),
    speed: 0.3 + Math.random() * 0.35,
    opacity: 0.12 + Math.random() * 0.18,
    size: 12 + Math.random() * 8,
    phase: (i / WORDS.length) * Math.PI * 2,
  }));

  const draw = () => {
    requestAnimationFrame(draw);
    ctx.clearRect(0, 0, W(), H());
    ctx.font = `500 13px 'JetBrains Mono', monospace`;

    particles.forEach(p => {
      p.y -= p.speed;
      p.x += Math.sin(p.y * 0.008 + p.phase) * 0.4;

      if (p.y < -30) {
        p.y = H() + 20;
        p.x = Math.random() * W();
      }

      // fade in near top, fade out at very top
      const fadeTop = Math.min(p.y / 80, 1);
      const alpha = p.opacity * fadeTop;

      const colors = ['#818cf8', '#c084fc', '#67e8f9', '#a5f3fc'];
      ctx.globalAlpha = alpha;
      ctx.fillStyle = colors[Math.floor(p.phase * 4 / (Math.PI * 2)) % colors.length];
      ctx.font = `600 ${p.size}px 'JetBrains Mono', monospace`;
      ctx.fillText(p.word, p.x, p.y);
    });

    ctx.globalAlpha = 1;
  };
  draw();
</script>
