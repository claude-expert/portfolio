---

<section id="work" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="reveal flex flex-wrap items-end justify-between gap-6 mb-16">
      <div>
        <div class="section-label">Featured Projects</div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Real systems,<br/>
          <span class="gradient-text">real results.</span>
        </h2>
      </div>
      <p class="text-zinc-500 max-w-sm text-sm leading-relaxed">
        Backend, cloud, and full-stack work across fintech, healthcare, AI, and enterprise SaaS — built for reliability, security, and production support.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((p, i) => (
        <article
          class={`reveal reveal-delay-${(i % 2) + 1} project-card card overflow-hidden group flex flex-col h-full relative p-6`}
          data-color={p.color}
        >
          <!-- Spotlight -->
          <div class="spotlight" style={`--spotlight-color: ${p.color};`}></div>

          <!-- Top accent bar -->
          <div class="absolute top-0 left-0 h-1 w-full" style={`background: linear-gradient(90deg, ${p.color}, ${p.color}44);`}></div>

          <div class="flex items-start justify-between gap-4 mb-5 relative z-10">
            <div class="flex items-center gap-3">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0"
                style={`background: ${p.color}15; border: 1px solid ${p.color}30;`}
              >
                {p.icon}
              </div>
              <div>
                <div class="text-white font-bold text-base">{p.name}</div>
                <div class="text-zinc-600 text-xs">{p.category}</div>
              </div>
            </div>
          </div>

          <p class="text-zinc-300 text-sm mb-2 font-semibold relative z-10">{p.tagline}</p>
          <p class="text-zinc-500 text-sm leading-relaxed relative z-10">{p.description}</p>

          <div class="space-y-2 my-4 relative z-10">
            {p.highlights.map((h) => (
              <div class="flex gap-3 items-start">
                <div class="flex-shrink-0 mt-1.5">
                  <div class="w-1.5 h-1.5 rounded-full" style={`background: ${p.color};`}></div>
                </div>
                <p class="text-zinc-400 text-sm leading-relaxed">{h}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-2 mb-4 relative z-10">
            {p.metrics.map((m) => (
              <span
                class="text-xs px-2.5 py-1 rounded-full font-medium"
                style={`background: ${p.color}10; color: ${p.color}; border: 1px solid ${p.color}25;`}
              >
                {m}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap gap-1.5 pt-4 border-t border-zinc-800/60 relative z-10 mt-auto">
            {p.stack.map((t) => (
              <span class="tech-badge-glow" style="font-size:11px;">{t}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  // Premium hover: lift + colored shadow + border glow + spotlight tracking
  document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
    const color = card.dataset.color ?? '#6366f1';

    card.addEventListener('mouseenter', () => {
      card.style.boxShadow   = `0 28px 72px -8px ${color}28, 0 0 0 1px ${color}35`;
      card.style.borderColor = `${color}45`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.boxShadow   = '';
      card.style.borderColor = '';
    });

    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--gx', `${(e.clientX - r.left) / r.width  * 100}%`);
      card.style.setProperty('--gy', `${(e.clientY - r.top)  / r.height * 100}%`);
    });
  });
</script>

<style>
  .project-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .project-card:hover {
    transform: translateY(-8px);
  }
</style>
